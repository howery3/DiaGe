{
  "expo": {
    "name": "DiaGe",
    "slug": "diage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "diage",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0714"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.diage.app",
      "buildNumber": "12",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "DiaGe uses your photo library to attach images of jewelry pieces, receipts, and warranty documents.",
        "NSCameraUsageDescription": "DiaGe uses your camera to photograph jewelry pieces and paperwork for your vault.",
        "NSUserNotificationUsageDescription": "DiaGe sends reminders for jewelry inspections and warranty renewals.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.diage.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "name": "DiaGe — Jewelry Organizer",
      "shortName": "DiaGe",
      "description": "DiaGe helps you track your jewelry collection, manage a wishlist, and set inspection reminders — all in one place.",
      "lang": "en",
      "themeColor": "#5B21B6",
      "backgroundColor": "#0A0714"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://DiaGe.replit.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "DiaGe uses your photo library to attach images of jewelry pieces, receipts, and warranty documents.",
          "cameraPermission": "DiaGe uses your camera to photograph jewelry pieces and paperwork for your vault."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "DiaGe uses your camera to scan retailer QR codes and sync jewelry catalogs to your wishlist."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5B21B6",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "95346f58-0da9-474e-bd0a-ef834b081197"
      },
      "privacyPolicyUrl": "https://DiaGe.replit.app/privacy"
    },
    "owner": "howery3"
  }
}
